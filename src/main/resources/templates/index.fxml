<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gm.tareas.controlador.IndexControlador">
   <children>
      <Label layoutX="181.0" layoutY="22.0" text="Sistema de tareas" textFill="#e63946">
         <font>
            <Font name="Arial Black" size="24.0" />
         </font></Label>
      <TableView fx:id="tareaTabla" layoutX="249.0" layoutY="93.0" prefHeight="200.0" prefWidth="337.0">
        <columns>
          <TableColumn fx:id="idTareaColumna" prefWidth="75.0" text="ID" />
          <TableColumn fx:id="nombreTareaColumna" prefWidth="75.0" text="TAREA" />
            <TableColumn fx:id="responsableColumna" prefWidth="98.0" text="RESPONSABLE" />
            <TableColumn fx:id="estatusColumna" prefWidth="87.0" text="ESTATUS" />
        </columns>
      </TableView>
      <AnchorPane layoutX="14.0" layoutY="317.0" prefHeight="69.0" prefWidth="573.0">
         <children>
            <Button fx:id="agregarBoton" layoutX="24.0" layoutY="22.0" mnemonicParsing="false" onAction="#agregarTarea" text="Agregar" />
            <Button fx:id="modificarBoton" layoutX="127.0" layoutY="22.0" mnemonicParsing="false" text="Modificar" />
            <Button fx:id="eliminarBoton" layoutX="235.0" layoutY="22.0" mnemonicParsing="false" text="Eliminar" />
            <Button fx:id="limpiarBoton" layoutX="326.0" layoutY="22.0" mnemonicParsing="false" text="Limpiar" />
         </children>
      </AnchorPane>
      <AnchorPane layoutX="14.0" layoutY="93.0" prefHeight="200.0" prefWidth="227.0">
         <children>
            <Label layoutX="14.0" layoutY="22.0" text="Tarea" />
            <Label layoutX="15.0" layoutY="75.0" text="Responsable" />
            <Label layoutX="15.0" layoutY="127.0" text="Estatus" />
            <TextField fx:id="nombreTareaTexto" layoutX="15.0" layoutY="39.0" />
            <TextField fx:id="responsableTexto" layoutX="15.0" layoutY="91.0" />
            <TextField fx:id="estatusTexto" layoutX="15.0" layoutY="144.0" />
         </children>
      </AnchorPane>
   </children>
</AnchorPane>
